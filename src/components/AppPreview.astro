<div class="app-window" id="app-preview">
    <div class="app-body">
        <!-- Email list -->
        <div class="email-list-col">
            <div class="titlebar">
                <div class="traffic-lights">
                    <span class="light red"></span>
                    <span class="light yellow"></span>
                    <span class="light green"></span>
                </div>
            </div>
            <div class="segment-control">
                <span class="segment-tab active">Inbox</span>
                <span class="segment-tab">Snoozed</span>
                <span class="segment-tab">Starred</span>
            </div>
            <div class="email-list" id="thread-list">
                {emails.map((email, i) => (
                    <div
                        class:list={["email-item", { selected: email.selected, unread: email.unread }]}
                        data-index={i}
                        data-sender={email.sender}
                        data-sender-email={email.senderEmail}
                        data-subject={email.subject}
                        data-time={email.time}
                        data-avatar={email.avatar}
                        data-avatar-color={email.avatarColor}
                        data-body={email.body}
                    >
                        <div class="email-item-inner">
                            <div class="email-indicator">
                                {email.unread && <span class="unread-dot"></span>}
                            </div>
                            <div class="email-content">
                                <div class="email-top">
                                    <span class="email-subject">{email.subject}</span>
                                    {email.starred && <svg class="star-icon" width="12" height="12" viewBox="0 0 24 24" fill="#f5c542" stroke="none"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>}
                                    <span class="email-time">{email.time}</span>
                                </div>
                                <div class="email-sender">{email.sender}</div>
                                <div class="email-snippet">{email.snippet}</div>
                            </div>
                        </div>
                        <div class="archive-check">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#28c840" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 8.5 6.5 12 13 4"/></svg>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Reading pane -->
        <div class="reading-pane">
            <h2 class="detail-subject" id="detail-subject">{selected.subject}</h2>
            <div class="email-card">
                <div class="sender-row">
                    <div class="avatar" id="detail-avatar" style={`background:${selected.avatarColor}`}>{selected.avatar}</div>
                    <div class="sender-info">
                        <div class="sender-name" id="detail-sender">{selected.sender}</div>
                        <div class="sender-email" id="detail-email">{selected.senderEmail}</div>
                    </div>
                    <div class="detail-time" id="detail-time">{selected.time}</div>
                </div>
                <div class="email-body-content" id="detail-body">
                    <Fragment set:html={selected.body} />
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    const container = document.getElementById('app-preview');
    if (!container) return;

    const threadList = container.querySelector('#thread-list');
    const detailSubject = container.querySelector('#detail-subject');
    const detailAvatar = container.querySelector('#detail-avatar');
    const detailSender = container.querySelector('#detail-sender');
    const detailEmail = container.querySelector('#detail-email');
    const detailTime = container.querySelector('#detail-time');
    const detailBody = container.querySelector('#detail-body');
    let count = 42;

    let selectedIndex = (() => {
        const rows = Array.from(threadList.querySelectorAll('.email-item'));
        return rows.findIndex(r => r.classList.contains('selected'));
    })();

    function getRows() {
        return Array.from(threadList.querySelectorAll('.email-item:not(.archived)'));
    }

    function updateSelection(rows, newIndex) {
        rows.forEach(r => r.classList.remove('selected'));
        if (newIndex >= 0 && newIndex < rows.length) {
            selectedIndex = newIndex;
            const row = rows[selectedIndex];
            row.classList.add('selected');
            updateReadingPane(row);
            row.scrollIntoView({ block: 'nearest' });
        }
    }

    function updateReadingPane(row) {
        detailSubject.textContent = row.dataset.subject;
        detailSender.textContent = row.dataset.sender;
        detailEmail.textContent = row.dataset.senderEmail;
        detailTime.textContent = row.dataset.time;
        detailAvatar.textContent = row.dataset.avatar;
        detailAvatar.style.background = row.dataset.avatarColor;
        detailBody.innerHTML = row.dataset.body;
    }

    function archiveRow(row) {
        if (row.classList.contains('archiving') || row.classList.contains('archived')) return;
        row.classList.add('archiving');

        setTimeout(() => {
            row.classList.add('archived');
            row.classList.remove('archiving');
            row.style.transform = '';
            count--;
            const remaining = getRows();
            if (remaining.length > 0) {
                const newIndex = Math.min(selectedIndex, remaining.length - 1);
                updateSelection(remaining, newIndex);
            }
        }, 250);
    }

    function archiveSelected() {
        const rows = getRows();
        if (rows.length === 0) return;
        archiveRow(rows[selectedIndex]);
    }

    // Trackpad swipe-to-archive
    let swipeState = { row: null, delta: 0, timeout: null };
    const SWIPE_THRESHOLD = 80;

    threadList.addEventListener('wheel', (e) => {
        if (Math.abs(e.deltaX) < Math.abs(e.deltaY)) return;
        if (e.deltaX <= 0) {
            // Only right-swipe archives
            if (swipeState.row) {
                swipeState.row.style.transform = '';
                swipeState.row = null;
                swipeState.delta = 0;
            }
            return;
        }

        e.preventDefault();

        const row = e.target.closest('.email-item:not(.archived):not(.archiving)');
        if (!row) return;

        if (swipeState.row !== row) {
            if (swipeState.row) swipeState.row.style.transform = '';
            swipeState.row = row;
            swipeState.delta = 0;
        }

        swipeState.delta += e.deltaX;
        const clamped = Math.max(0, Math.min(swipeState.delta, SWIPE_THRESHOLD + 40));
        row.style.transform = `translateX(${clamped}px)`;
        row.style.transition = 'none';

        clearTimeout(swipeState.timeout);

        if (clamped >= SWIPE_THRESHOLD) {
            // Select this row first, then archive
            const rows = getRows();
            const idx = rows.indexOf(row);
            if (idx !== -1) {
                updateSelection(rows, idx);
            }
            row.style.transition = '';
            archiveRow(row);
            swipeState.row = null;
            swipeState.delta = 0;
        } else {
            swipeState.timeout = setTimeout(() => {
                row.style.transition = 'transform 0.15s ease-out';
                row.style.transform = '';
                swipeState.row = null;
                swipeState.delta = 0;
            }, 200);
        }
    }, { passive: false });

    // Click to select
    threadList.addEventListener('click', (e) => {
        const row = e.target.closest('.email-item:not(.archived):not(.archiving)');
        if (!row) return;
        const rows = getRows();
        const idx = rows.indexOf(row);
        if (idx !== -1) {
            updateSelection(rows, idx);
        }
    });

    document.addEventListener('keydown', (e) => {
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

        const rows = getRows();
        if (rows.length === 0) return;

        if (e.key === 'j' || e.key === 'ArrowDown') {
            e.preventDefault();
            if (selectedIndex < rows.length - 1) {
                updateSelection(rows, selectedIndex + 1);
            }
        } else if (e.key === 'k' || e.key === 'ArrowUp') {
            e.preventDefault();
            if (selectedIndex > 0) {
                updateSelection(rows, selectedIndex - 1);
            }
        } else if (e.key === 'e') {
            e.preventDefault();
            archiveSelected();
        }
    });
})();
</script>

