---
import '../../src/styles/globals.css';

interface Props {
    title: string;
    description?: string;
}

const { title, description = "A fast, keyboard-first Gmail client for Mac. Native, private, and built for people who live in their inbox." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://emdashmail.com');
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="canonical" href={canonicalURL.href} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:site_name" content="Emdash" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    </head>
    <body class="site-body">
        <nav class="site-nav">
            <div class="nav-inner">
                <a href="/" class="nav-logo" aria-label="Emdash home">
                    em<span class="logo-dash">-</span>dash
                </a>
            </div>
        </nav>

        <main class="site-main">
            <slot />
        </main>

        <footer class="site-footer">
            <div class="footer-logo">em<span class="logo-dash">-</span>dash</div>
            <div class="footer-links">
                <a href="/privacy">Privacy</a>
                <a href="/terms">Terms</a>
                <a href="mailto:hello@emdashmail.com">Support</a>
                <a href="mailto:hello@emdashmail.com">hello@emdashmail.com</a>
            </div>
            <p class="footer-copy">&copy; {new Date().getFullYear()} Emdash. All rights reserved.</p>
        </footer>
    </body>
</html>

<style is:global>
    :root {
        --bg1: #111113;
        --bg2: #18181b;
        --bg3: #1e1e22;
        --text: #f4f4f6;
        --muted: #a2a4aa;
        --line: #2a2b31;
        --teal: #2eb8c8;
        --mono: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        --serif: 'Instrument Serif', Georgia, serif;
        --sans: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
    }

    * {
        box-sizing: border-box;
    }

    html,
    body {
        margin: 0;
        background: radial-gradient(circle at 20% 0%, rgba(46, 184, 200, 0.07), transparent 34%), var(--bg1);
    }

    .site-body {
        font-family: var(--sans);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    .site-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 52px;
        z-index: 30;
        background: rgba(17, 17, 19, 0.8);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .nav-inner {
        max-width: 1120px;
        height: 100%;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        align-items: center;
    }

    .nav-logo {
        color: #d4d6dc;
        text-decoration: none;
        font-size: 0.92rem;
        letter-spacing: 0.08em;
        text-transform: lowercase;
    }

    .logo-dash {
        color: var(--teal);
    }

    .site-main {
        padding-top: 52px;
        min-height: calc(100vh - 52px);
    }

    .site-footer {
        max-width: 1120px;
        margin: 0 auto;
        padding: 28px 24px 34px;
        color: var(--muted);
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 16px;
        font-size: 0.82rem;
    }

    .footer-logo {
        letter-spacing: 0.08em;
    }

    .footer-links {
        display: flex;
        justify-content: center;
        gap: 16px;
        white-space: nowrap;
    }

    .site-footer a {
        color: var(--muted);
        text-decoration: none;
    }

    .site-footer a:hover {
        color: #d8dce2;
    }

    .footer-copy {
        justify-self: end;
        margin: 0;
        text-align: right;
    }

    @media (max-width: 840px) {
        .site-footer {
            grid-template-columns: 1fr;
            justify-items: center;
            text-align: center;
        }

        .footer-copy {
            justify-self: center;
            text-align: center;
        }

        .footer-links {
            flex-wrap: wrap;
        }
    }
</style>
