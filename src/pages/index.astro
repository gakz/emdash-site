---
import Layout from '../layouts/Layout.astro';
---

<Layout title="emdash — A fast, focused Gmail client for macOS">
    <section class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16 py-16 sm:py-24 lg:py-32">
        <!-- Left: Copy + CTA -->
        <div class="flex-1 max-w-xl">
            <h1 class="text-primary mb-6">
                A fast, focused Gmail client for macOS.
            </h1>
            <p class="text-lg sm:text-xl leading-relaxed text-muted mb-10">
                emdash is built for keyboard-first email and calm inbox-zero workflows.
            </p>
            <div class="flex flex-wrap items-center gap-4 mb-4">
                <a href="#download" class="btn btn-primary btn-lg">
                    Download for Mac
                </a>
                <a href="#screenshots" class="btn btn-secondary btn-lg">
                    View screenshots
                </a>
            </div>
            <p class="text-sm text-muted">
                Free download&nbsp;&middot;&nbsp;macOS 13+
            </p>
        </div>

        <!-- Right: Product screenshot -->
        <div class="flex-1 w-full max-w-2xl">
            <img
                src="/images/screenshot.svg"
                alt="emdash email client interface showing a clean inbox with keyboard shortcuts"
                class="w-full h-auto rounded-xl shadow-lg"
            />
        </div>
    </section>
</Layout>
