---
import Layout from '../layouts/Layout.astro';

const commandRows = [
    { label: 'Go to Inbox', shortcut: 'G then I' },
    { label: 'Archive', shortcut: 'E' },
    { label: 'Compose new message', shortcut: 'C' },
    { label: 'Snooze for tomorrow', shortcut: 'S' },
];
---

<Layout title="Emdash — Fast, keyboard-first Gmail for Mac">
    <section class="hero reveal">
        <div class="hero-grid-mask" aria-hidden="true"></div>
        <div class="hero-inner">
            <div class="hero-badge">
                <span class="dot" aria-hidden="true"></span>
                <span class="badge-label">Fast, keyboard-first Gmail for Mac</span>
            </div>

            <h1>Move through email effortlessly</h1>

            <p class="hero-subhead">Powerful shortcuts, a clean interface, and a native Mac experience.</p>

            <div class="hero-cta-row">
                <a href="https://apps.apple.com/app/emdash" class="btn-primary">Download for Mac</a>
                <span class="cta-note">14-day free trial. One-time purchase after.</span>
            </div>
        </div>

        <div class="hero-window reveal d1">
            <img src="/app-screenshot.png" alt="Emdash email client for Mac" width="1440" height="900" />
        </div>
    </section>

    <!-- SECTION 2: BUILT FOR FAST TRIAGE -->
    <section class="section reveal d1">
        <div class="section-inner center copy-block">
            <h2>Built for fast triage</h2>
            <p>Move quickly through your inbox with instant navigation, powerful shortcuts, and a command palette built for speed.</p>
        </div>
        
        <div class="section-inner triage-visuals mt-visual">
            <div class="palette-window reveal d3">
                <div class="palette-search-row">
                    <span class="search-icon">⌘</span>
                    <span id="typewriter">Go to Inbox</span>
                </div>
                <div class="palette-results">
                    {commandRows.map((row, index) => (
                        <div class:list={["palette-item", { active: index === 0 }] }>
                            <span>{row.label}</span>
                            <kbd>{row.shortcut}</kbd>
                        </div>
                    ))}
                </div>
                <div class="palette-footer">↑↓ navigate · ↵ select · esc dismiss</div>
            </div>
        </div>
    </section>

    <!-- SECTION 3: BUILT FOR macOS -->
    <section class="section reveal d1">
        <div class="section-inner center copy-block">
            <h2>Built for macOS</h2>
            <p>Fast scrolling, native typography, and zero lag — designed specifically for Mac.</p>
        </div>
        
        <div class="section-inner macos-visuals mt-visual reveal d2">
            <div class="macos-mock">
                <div class="macos-header">
                    <div class="macos-dots">
                        <span></span><span></span><span></span>
                    </div>
                </div>
                <div class="macos-body">
                    <div class="macos-item blur-effect">Vibrant blur</div>
                    <div class="macos-item typography">Native Typography</div>
                    <div class="macos-item smooth-scroll">60fps Smooth Scrolling</div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 4: WRITING FEELS FAST -->
    <section class="section reveal d1">
        <div class="section-inner center copy-block">
            <h2>Writing feels fast</h2>
            <p>Reply instantly with a focused composer that stays out of the way.</p>
        </div>

        <div class="section-inner composer-visual mt-visual reveal d2">
            <div class="composer-mock">
                <div class="composer-header">
                    <span>To: Jason Doe</span>
                    <span>Subject: Project update</span>
                </div>
                <div class="composer-body">
                    <p>The new designs look great. Let's move forward with the implementation phase next week.</p>
                    <div class="composer-cursor"></div>
                </div>
                <div class="composer-footer">
                    <div class="btn-primary composer-send">Send ⌘ ↵</div>
                </div>
            </div>
        </div>
    </section>

    <!-- FINAL CTA -->
    <section class="section final-cta reveal d1">
        <div class="section-inner center">
            <h2>Try Emdash free</h2>
            <p class="final-cta-subtext">One-time purchase. No subscription.</p>
            <a href="https://apps.apple.com/app/emdash" class="btn-primary">Download for Mac</a>
        </div>
    </section>
</Layout>

<script>
(() => {
    const reveals = Array.from(document.querySelectorAll('.reveal'));
    const revealObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('show');
                    revealObserver.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.15 }
    );

    reveals.forEach((item) => revealObserver.observe(item));

    const commands = ['Go to Inbox', 'Archive', 'Compose new message', 'Snooze for tomorrow'];
    const output = document.getElementById('typewriter');
    if (output) {
        let commandIndex = 0;
        let charIndex = 0;
        let deleting = false;
        let pauseUntil = 0;

        setInterval(() => {
            const now = Date.now();
            if (now < pauseUntil) return;

            const command = commands[commandIndex];

            if (!deleting) {
                charIndex += 1;
                output.textContent = command.slice(0, charIndex);
                if (charIndex >= command.length) {
                    deleting = true;
                    pauseUntil = now + 800;
                }
            } else {
                charIndex -= 1;
                output.textContent = command.slice(0, Math.max(charIndex, 0));
                if (charIndex <= 0) {
                    deleting = false;
                    commandIndex = (commandIndex + 1) % commands.length;
                    pauseUntil = now + 220;
                }
            }
        }, 60);
    }
})();
</script>

<style>
    .section {
        padding: 64px 24px;
    }

    .section-inner {
        width: min(1120px, 100%);
        margin: 0 auto;
    }

    .copy-block {
        max-width: 540px;
        margin: 0 auto;
    }

    .copy-block h2 {
        margin-bottom: 12px;
    }

    .copy-block p {
        margin: 0 auto;
    }

    .mt-visual {
        margin-top: 40px;
    }

    h1,
    h2,
    h3,
    p {
        margin: 0;
    }

    h1,
    h2 {
        font-family: var(--serif);
        font-weight: 400;
        letter-spacing: -0.02em;
    }

    h2 {
        font-size: clamp(2rem, 5vw, 3rem);
    }

    p {
        color: #d1d6df;
        line-height: 1.5;
        font-size: 1.05rem;
    }

    .center {
        text-align: center;
    }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        padding: 9px 18px;
        color: #091114;
        text-decoration: none;
        font-weight: 700;
        background: #2eb8c8;
        border: 1px solid rgba(255, 255, 255, 0.18);
        box-shadow: 0 4px 20px rgba(46, 184, 200, 0.18);
        transition: background 0.2s ease, transform 0.2s ease;
    }

    .btn-primary:hover {
        background: #39c9da;
        transform: translateY(-1px);
    }

    .hero {
        min-height: calc(100vh - 52px);
        padding: 68px 24px 32px;
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 32px;
    }

    .hero::before {
        content: '';
        position: absolute;
        inset: 4% auto auto 50%;
        width: clamp(420px, 60vw, 820px);
        height: clamp(300px, 34vw, 460px);
        transform: translateX(-50%);
        background: radial-gradient(circle, rgba(46, 184, 200, 0.26) 0%, rgba(46, 184, 200, 0) 68%);
        pointer-events: none;
        z-index: 0;
    }

    .hero-grid-mask {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(to right, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
        background-size: 28px 28px;
        mask-image: radial-gradient(circle at center, black 22%, transparent 80%);
        opacity: 0.28;
        pointer-events: none;
        z-index: 0;
    }

    .hero-inner {
        width: min(820px, 100%);
        margin: 0 auto;
        text-align: center;
        position: relative;
        z-index: 1;
    }

    .hero-badge {
        width: fit-content;
        margin: 0 auto 20px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(30, 30, 34, 0.95);
        border: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #2eb8c8;
        box-shadow: 0 0 0 0 rgba(46, 184, 200, 0.6);
        animation: pulse 1.5s ease-out infinite;
    }

    @keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(46, 184, 200, 0.6); }
        100% { box-shadow: 0 0 0 13px rgba(46, 184, 200, 0); }
    }

    .badge-label,
    .cta-note,
    kbd,
    .palette-footer,
    .final-cta-subtext {
        font-family: var(--mono);
    }

    .badge-label {
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        color: #e2e6eb;
    }

    h1 {
        font-size: clamp(2.6rem, 8vw, 4.4rem);
        line-height: 1;
        margin-bottom: 16px;
    }

    .hero-subhead {
        width: 90%;
        max-width: 560px;
        margin: 0 auto;
        font-size: 1.05rem;
        color: #c9ccd4;
    }

    .hero-cta-row {
        margin-top: 28px;
        margin-bottom: 28px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: center;
        justify-content: center;
    }

    .cta-note {
        color: #adb1b8;
        font-size: 0.76rem;
        letter-spacing: 0.04em;
    }

    .hero-window {
        width: min(1120px, calc(100vw - 48px));
        margin: 0 auto;
        background: var(--bg2);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
        position: relative;
        z-index: 1;
    }

    .hero-window img {
        width: 100%;
        display: block;
        height: auto;
    }

    /* TRIAGE VISUALS */
    .triage-visuals {
        display: flex;
        justify-content: center;
        gap: 16px;
        align-items: start;
        max-width: 480px;
        margin: 0 auto;
    }

    kbd {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 32px;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.7rem;
        color: #c9d1da;
        background: #202127;
        border: 1px solid #32343d;
    }

    .palette-window {
        background: var(--bg2);
        border: 1px solid var(--line);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .palette-search-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 16px;
        border-bottom: 1px solid var(--line);
        color: #dde2ea;
        min-height: 52px;
    }

    .search-icon {
        color: #2eb8c8;
        font-size: 0.95rem;
    }

    #typewriter {
        font-family: var(--mono);
        color: #d5d8df;
        letter-spacing: 0.01em;
        font-size: 0.85rem;
    }

    .palette-results {
        padding: 6px;
    }

    .palette-item {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 8px 10px;
        border-radius: 8px;
        color: #c6cad2;
        font-size: 0.85rem;
    }

    .palette-item.active {
        background: rgba(46, 184, 200, 0.14);
        color: #e7fdff;
    }

    .palette-footer {
        padding: 10px 14px;
        border-top: 1px solid var(--line);
        color: #8f95a0;
        font-size: 0.7rem;
        letter-spacing: 0.02em;
    }

    /* MACOS VISUALS */
    .macos-visuals {
        display: flex;
        justify-content: center;
    }

    .macos-mock {
        width: 100%;
        max-width: 600px;
        background: rgba(30, 30, 34, 0.6);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
    }

    .macos-header {
        display: flex;
        align-items: center;
        padding: 14px 16px;
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .macos-dots {
        display: flex;
        gap: 6px;
    }

    .macos-dots span {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #424550;
    }

    .macos-body {
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .macos-item {
        padding: 16px;
        border-radius: 10px;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
    }

    .blur-effect {
        background: rgba(46, 184, 200, 0.05);
        color: #2eb8c8;
        border: 1px solid rgba(46, 184, 200, 0.1);
    }

    .typography {
        background: rgba(255, 255, 255, 0.03);
        color: #e2e6eb;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        font-weight: 500;
        border: 1px solid transparent;
    }

    .smooth-scroll {
        background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.06));
        color: #c9ccd4;
        border: 1px solid transparent;
    }

    /* COMPOSER VISUALS */
    .composer-visual {
        display: flex;
        justify-content: center;
    }

    .composer-mock {
        width: 100%;
        max-width: 540px;
        background: var(--bg2);
        border: 1px solid var(--line);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
        text-align: left;
    }

    .composer-header {
        display: flex;
        flex-direction: column;
        border-bottom: 1px solid var(--line);
    }

    .composer-header span {
        padding: 12px 16px;
        font-size: 0.9rem;
        color: #e2e6eb;
    }

    .composer-header span:first-child {
        border-bottom: 1px solid var(--line);
    }

    .composer-body {
        padding: 16px;
        min-height: 120px;
        position: relative;
    }

    .composer-body p {
        font-size: 0.95rem;
        color: #c9ccd4;
        margin: 0;
    }

    .composer-cursor {
        display: inline-block;
        width: 2px;
        height: 1.1rem;
        background: #2eb8c8;
        vertical-align: middle;
        margin-left: 4px;
        animation: blink 1s step-end infinite;
    }

    @keyframes blink {
        50% { opacity: 0; }
    }

    .composer-footer {
        padding: 12px 16px;
        background: rgba(255, 255, 255, 0.02);
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: flex-end;
    }

    .composer-send {
        padding: 6px 14px;
        font-size: 0.8rem;
        border-radius: 6px;
        cursor: pointer;
        display: inline-block;
        background: #2eb8c8;
        color: #091114;
        font-weight: 600;
        border: none;
    }

    /* FINAL CTA */
    .final-cta {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        padding-top: 60px;
        padding-bottom: 100px;
    }

    .final-cta h2 {
        margin-bottom: 6px;
    }

    .final-cta-subtext {
        color: #adb1b8;
        font-size: 0.76rem;
        letter-spacing: 0.04em;
        margin-bottom: 12px;
    }

    .reveal {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .reveal.show {
        opacity: 1;
        transform: translateY(0);
    }

    .d1 { transition-delay: 0.05s; }
    .d2 { transition-delay: 0.1s; }
    .d3 { transition-delay: 0.15s; }

    @media (max-width: 680px) {
        .section {
            padding: 48px 20px;
        }

        .hero {
            padding: 48px 20px 24px;
        }

        .hero-badge {
            padding: 7px 12px;
        }

        .badge-label {
            font-size: 0.68rem;
        }

        .hero-window {
            width: calc(100vw - 16px);
        }

        .hero-cta-row {
            flex-direction: column;
        }

        .btn-primary {
            width: 100%;
            max-width: 280px;
        }
    }
</style>