---
import Layout from '../layouts/Layout.astro';
import AppPreview from '../components/AppPreview.astro';
---

<Layout title="Emdash — Fast, keyboard-first Gmail for Mac">
    <div class="hero">
        <div class="hero-inner">
            <div class="emdash-shape">
                <svg class="emdash-noise" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                    <filter id="grain">
                        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
                        <feColorMatrix type="saturate" values="0" />
                    </filter>
                    <rect width="100%" height="100%" filter="url(#grain)" />
                </svg>
            </div>
            <div class="app-preview-wrapper">
                <AppPreview />
            </div>
        </div>
    </div>
    <div style="display: flex; justify-content: center;">
        <div class="bottom-bar">
            <h1 class="headline">Email. Done faster.</h1>
            <div class="features">
                <span class="feature"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>Fast</span>
                <span class="feature"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>Native</span>
                <span class="feature"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>Private</span>
                <span class="feature"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>Gmail-only</span>
            </div>
        </div>
    </div>
</Layout>

<style>
    .hero {
        display: flex;
        justify-content: center;
        align-items: flex-end;
        height: 65vh;
        padding-bottom: 4vh;
    }
    .hero-inner {
        position: relative;
        width: 90%;
        max-width: 1200px;
        margin-left: -2%;
        clip-path: inset(-9999px -9999px 0 -9999px);
    }
    .bottom-bar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        width: 90%;
        max-width: 1200px;
        margin-left: -2%;
    }
    .headline {
        margin: 12px 0 0 0;
        font-size: 17px;
        font-weight: 600;
        color: #666;
        line-height: 1.6;
    }
    .app-preview-wrapper {
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-45%);
        width: 70%;
        overflow: hidden;
        border-radius: 12px 12px 0 0;
        box-shadow: inset 0 -3px 0 0 black, 10px -10px 30px rgba(0,0,0,0.15);
    }
    .features {
        display: flex;
        gap: 16px;
        margin: 14px 24px 0 0;
    }
    .feature {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 15px;
        color: #888;
        font-weight: 400;
    }
    .feature svg {
        opacity: 0.7;
    }
    .emdash-shape {
        position: relative;
        overflow: hidden;
        width: 100%;
        aspect-ratio: 563 / 76;
        clip-path: polygon(2.238% 0%, 99.857% 0%, 97.62% 99.43%, 0% 99.43%);
        background:
            radial-gradient(ellipse 80% 120% at 20% 50%, rgba(109, 90, 163, 0.6), transparent 70%),
            radial-gradient(ellipse 90% 140% at 75% 40%, rgba(99, 102, 241, 0.5), transparent 65%),
            radial-gradient(ellipse 70% 100% at 50% 60%, rgba(139, 122, 196, 0.4), transparent 60%),
            linear-gradient(135deg, #4c3a6e, #5b4d8a, #6a5f9e, #5b4d8a, #4c3a6e);
        background-size: 200% 200%, 200% 200%, 200% 200%, 100% 100%;
        animation:
            drift-1 25s ease-in-out infinite,
            drift-2 30s ease-in-out infinite,
            drift-3 35s ease-in-out infinite;
    }

    .emdash-noise {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0.12;
        mix-blend-mode: overlay;
        pointer-events: none;
    }

    @keyframes drift-1 {
        0%, 100% { background-position: 20% 40%, 80% 50%, 50% 60%, center; }
        33%      { background-position: 60% 55%, 30% 45%, 70% 40%, center; }
        66%      { background-position: 35% 45%, 65% 60%, 40% 50%, center; }
    }

    @keyframes drift-2 {
        0%, 100% { background-position: 20% 40%, 80% 50%, 50% 60%, center; }
        50%      { background-position: 50% 50%, 50% 55%, 55% 45%, center; }
    }

    @keyframes drift-3 {
        0%, 100% { background-position: 20% 40%, 80% 50%, 50% 60%, center; }
        25%      { background-position: 40% 50%, 60% 45%, 45% 55%, center; }
        75%      { background-position: 30% 45%, 70% 55%, 60% 45%, center; }
    }

    @media (max-width: 768px) {
        .hero {
            height: 50vh;
        }
        .hero-inner {
            width: 95%;
            margin-left: 0;
        }
        .app-preview-wrapper {
            width: 90%;
            transform: translateX(-50%);
        }
        .bottom-bar {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
            width: 95%;
            margin-left: 0;
        }
        .features {
            flex-wrap: wrap;
            gap: 12px;
            margin: 0;
        }
        .feature {
            font-size: 13px;
        }
    }

    @media (prefers-color-scheme: dark) {
        .headline {
            color: #aaa;
        }
        .feature {
            color: #777;
        }
        .app-preview-wrapper {
            box-shadow: inset 0 -3px 0 0 #333, 10px -10px 30px rgba(0,0,0,0.4);
        }
    }
</style>
